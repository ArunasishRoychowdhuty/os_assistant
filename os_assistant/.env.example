# OS Assistant environment template
# Copy this file to .env and fill in the keys for your selected provider.
# Supported providers: openai, anthropic, gemini, nvidia

AI_PROVIDER=gemini

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional model overrides
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_MODEL=gemini-2.5-pro
NVIDIA_MODEL=z-ai/glm-5.1
NVIDIA_FALLBACK_MODEL=moonshotai/kimi-k2.6

# Runtime mode
# Keep this off for fastest/simple PyQt direct-control mode.
ENABLE_WEBSOCKET_BRIDGE=false
SCREEN_SCAN_INTERVAL=0.5
ENABLE_DXCAM=true

# Safety behavior is configured in config.py.
# CONFIRM_DESTRUCTIVE is intentionally code-controlled by default.
